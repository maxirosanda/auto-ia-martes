      "parameters": {
        "jsCode": "// 1. Accedemos al texto generado por Gemini\nconst rawText = $json.content.parts[0].text;\n\n// 2. Parseamos el string a JSON real\nlet parsed;\n\ntry {\n  parsed = JSON.parse(rawText);\n} catch (error) {\n  throw new Error(\"Error parseando JSON: \" + error.message);\n}\n\n// 3. Convertimos al formato que n8n espera (array de items)\nreturn parsed.map(item => ({\n  json: {\n    text: item.text,\n    source: item.source,\n    chunk_index: item.chunk_index,\n    chunk_id: item.chunk_id\n  }\n}));"
      },
