    {
      "parameters": {
        "jsCode": "// Datos del archivo (vienen del nodo Edit Fields)\nconst fileData = $items(\"Edit Fields\")[0].json;\n\n// Datos principales (los registros)\nconst data = items.map(i => i.json);\n\n// Fuente (podés cambiarlo si querés)\nconst source = fileData.fileName || \"unknown\";\n\n// Transformación\nreturn data.map((item, index) => {\n  \n  // Convertimos el objeto a texto clave:valor\n  const text = Object.entries(item)\n    .map(([key, value]) => `${key}: ${value}`)\n    .join(\", \");\n\n  return {\n    json: {\n      text,\n      source,\n      chunk_index: index,\n      chunk_id: `${source}_${index}`\n    }\n  };\n});"
      },
