    {
      "parameters": {
        "jsCode": "// Accedemos a la data de la respuesta (ajusta la ruta según tu JSON)\nconst base64Data = items[0].json.candidates[0].content.parts[0].inlineData.data;\nconst mimeType = items[0].json.candidates[0].content.parts[0].inlineData.mimeType || 'image/jpeg';\n\n// n8n requiere que devolvamos un array de objetos\nreturn [\n  {\n    json: items[0].json, // Mantenemos los datos originales por si los necesitas\n    binary: {\n      data: await this.helpers.prepareBinaryData(\n        Buffer.from(base64Data, 'base64'), // Convertimos la cadena a Buffer\n        'archivo_generado.jpg',           // Nombre opcional del archivo\n        mimeType                          // Tipo de archivo\n      ),\n    },\n  },\n];"
