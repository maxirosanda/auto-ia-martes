    {
      "parameters": {
        "jsCode": "const globalData = $getWorkflowStaticData('global');\n\n// Validar embeddings guardados\nif (!globalData.embeddings || !Array.isArray(globalData.embeddings)) {\n  throw new Error('No hay embeddings en memoria global');\n}\n\n// Obtener embedding de la pregunta (primer item del input)\nconst queryEmbedding = $input.first().json.embedding.values;\n\n// Embeddings de los fragmentos guardados\nconst storedEmbeddings = globalData.embeddings;\n\n// Función cosine similarity\nfunction cosineSimilarity(a, b) {\n  let dot = 0.0;\n  let normA = 0.0;\n  let normB = 0.0;\n\n  for (let i = 0; i < a.length; i++) {\n    dot += a[i] * b[i];\n    normA += a[i] * a[i];\n    normB += b[i] * b[i];\n  }\n\n  normA = Math.sqrt(normA);\n  normB = Math.sqrt(normB);\n\n  if (normA === 0 || normB === 0) return 0;\n\n  return dot / (normA * normB);\n}\n\n// Calcular similitudes contra todos los chunks\nconst similarities = storedEmbeddings.map(chunkEmbedding =>\n  cosineSimilarity(queryEmbedding, chunkEmbedding)\n);\n\n// Normalizar [−1,1] → [0,1]\nconst normalizedSimilarities = similarities.map(s => (s + 1) / 2);\n\n// Score global (promedio)\nconst score =\n  normalizedSimilarities.reduce((acc, val) => acc + val, 0) /\n  normalizedSimilarities.length;\n\n// 🔥 (opcional pero MUY útil en RAG)\nconst ranked = normalizedSimilarities\n  .map((sim, index) => ({\n    index,\n    similarity: sim,\n    embedding: storedEmbeddings[index]\n  }))\n  .sort((a, b) => b.similarity - a.similarity);\n\n// Output\nreturn [\n  {\n    json: {\n      score,\n      similarities: normalizedSimilarities,\n      topK: ranked.slice(0, 5) // los 5 más parecidos\n    }\n  }\n];"
      },
