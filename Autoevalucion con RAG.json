        "jsCode": "const globalData = $getWorkflowStaticData('global');\n\n// Asegurar estructura correcta (array)\nif (!Array.isArray(globalData.embeddings)) {\n  globalData.embeddings = [];\n}\n\n// Guardar (podés elegir push o replace)\n\n// OPCIÓN 1: reemplazar\nglobalData.embeddings = $input.all().map(\n  item => item.json.embedding.values\n);\n\n// OPCIÓN 2: acumular (más común en RAG)\n// globalData.embeddings.push(data);\n\nreturn $input.all();"
