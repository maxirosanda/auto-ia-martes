    {
      "parameters": {
        "jsCode": "// 1. Obtener el texto crudo\nconst raw = $json.content.parts[0].text;\n\n// 2. Limpiar el markdown ```json ... ```\nconst cleaned = raw\n  .replace(/```json/g, \"\")\n  .replace(/```/g, \"\")\n  .trim();\n\n// 3. Convertir a objeto JSON\nconst data = JSON.parse(cleaned);\n\n// 4. Generar HTML\nconst html = `\n<!DOCTYPE html>\n<html>\n<head>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      line-height: 1.6;\n      color: #333;\n    }\n    .container {\n      max-width: 600px;\n      margin: auto;\n      padding: 20px;\n    }\n    h1 {\n      color: #4CAF50;\n    }\n    .section {\n      margin-bottom: 20px;\n    }\n    .hashtags {\n      color: #1DA1F2;\n      font-size: 14px;\n    }\n    .box {\n      background: #f4f4f4;\n      padding: 15px;\n      border-radius: 8px;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"container\">\n    \n    <h1>${data.email.subject}</h1>\n\n    <div class=\"section box\">\n      <p>${data.resumen}</p>\n    </div>\n\n    <div class=\"section\">\n      <h3>Email</h3>\n      <p>${data.email.body.replace(/\\n/g, \"<br>\")}</p>\n    </div>\n\n    <div class=\"section\">\n      <h3>LinkedIn</h3>\n      <p>${data.linkedin.post.replace(/\\n/g, \"<br>\")}</p>\n      <p class=\"hashtags\">${data.linkedin.hashtags.join(\" \")}</p>\n    </div>\n\n    <div class=\"section\">\n      <h3>Instagram</h3>\n      <p>${data.instagram.caption.replace(/\\n/g, \"<br>\")}</p>\n      <p class=\"hashtags\">${data.instagram.hashtags.join(\" \")}</p>\n    </div>\n\n    <div class=\"section\">\n      <h3>Twitter</h3>\n      <p>${data.twitter.post}</p>\n    </div>\n\n  </div>\n</body>\n</html>\n`;\n\n// 5. Devolver HTML listo\nreturn [\n  {\n    json: {\n      html: html,\n      subject: data.email.subject\n    }\n  }\n];;"
      },
